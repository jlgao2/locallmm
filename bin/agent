#!/usr/bin/env bash
# agent — preflight the local stack, then launch `hermes chat` from cwd.
# Hermes auto-loads AGENTS.md from the current directory, so cd into your
# project first.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PORT="${MLX_PORT:-8000}"

if ! curl -fsS "http://127.0.0.1:$PORT/v1/models" >/dev/null 2>&1; then
  echo "agent: local stack not responding on :$PORT — starting it..."
  "$ROOT/bin/locallmm" start
  for _ in $(seq 1 60); do
    curl -fsS "http://127.0.0.1:$PORT/v1/models" >/dev/null 2>&1 && break
    sleep 1
  done
fi

exec hermes chat "$@"

#!/usr/bin/env python3
"""vlm — quick vision chat against the local mlx-vlm server.

Attach images by passing file paths, http(s) URLs, or data: URIs as
arguments; everything else is the prompt. Local paths are sent as absolute
paths so the server (which runs from a different cwd) can read them.

  vlm "what's in this?" shot.png
  vlm describe screenshot.png ~/Pictures/diagram.jpg
  cat notes.txt | vlm "use this context" chart.png
  vlm                       # interactive; attach images per line by path/URL
"""
import json
import os
import shlex
import sys
import urllib.request

PORT = os.environ.get("VLM_PORT", "8001")
MODEL = os.environ.get("VLM_MODEL", "mlx-community/Qwen3-VL-30B-A3B-Instruct-4bit")
URL = f"http://127.0.0.1:{PORT}/v1/chat/completions"


def split_tokens(tokens: list) -> tuple:
    """Split tokens into (prompt_text, image_refs)."""
    images, words = [], []
    for tok in tokens:
        if tok.startswith(("http://", "https://", "data:")):
            images.append(tok)
        elif os.path.isfile(tok):
            images.append(os.path.abspath(tok))
        else:
            words.append(tok)
    return " ".join(words), images


def make_content(text: str, images: list):
    """OpenAI content: plain string when text-only, else a typed array."""
    if not images:
        return text
    content = []
    if text:
        content.append({"type": "text", "text": text})
    for img in images:
        content.append({"type": "image_url", "image_url": {"url": img}})
    return content


def build_payload(messages: list) -> dict:
    # Name the model explicitly: without it the server falls back to a default
    # model (nanoLLaVA) that downloads and then crashes its generation thread.
    return {"model": MODEL, "messages": messages, "stream": False}


def ask(messages: list) -> str:
    payload = json.dumps(build_payload(messages)).encode()
    req = urllib.request.Request(
        URL, data=payload, headers={"Content-Type": "application/json"}
    )
    with urllib.request.urlopen(req, timeout=900) as resp:
        data = json.load(resp)
    return data["choices"][0]["message"]["content"]


def ask_with_status(messages: list) -> str:
    sys.stderr.write("  (looking…)")
    sys.stderr.flush()
    try:
        answer = ask(messages)
    finally:
        sys.stderr.write("\r" + " " * 32 + "\r")
        sys.stderr.flush()
    return answer


def main() -> None:
    stdin_text = "" if sys.stdin.isatty() else sys.stdin.read().strip()
    if len(sys.argv) > 1 or stdin_text:  # one-shot mode
        text, images = split_tokens(sys.argv[1:])
        if stdin_text:
            text = f"{text}\n\n{stdin_text}" if text else stdin_text
        if not text and not images:
            print("vlm: nothing to do (give a prompt and/or an image)")
            return
        messages = [{"role": "user", "content": make_content(text, images)}]
        print(ask_with_status(messages))
        return

    print("locallmm vision chat — attach images by path/URL; Ctrl-D or 'exit' to quit")
    history: list = []
    while True:
        try:
            line = input("\n› ")
        except EOFError:
            print()
            break
        if line.strip() in {"exit", "quit"}:
            break
        if not line.strip():
            continue
        text, images = split_tokens(shlex.split(line))
        history.append({"role": "user", "content": make_content(text, images)})
        try:
            answer = ask_with_status(history)
        except Exception as exc:
            print(f"error: {exc}\n(is the vision server up? run: locallmm vision-start)")
            history.pop()
            continue
        print(f"\n{answer}")
        history.append({"role": "assistant", "content": answer})


if __name__ == "__main__":
    main()
